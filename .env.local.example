# Supabase (Next.js client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase (server/agents/scripts)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Site URL (used for OAuth callbacks)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Runway test credentials (only for local debug scripts like trigger-tidal-auth.mjs)
RUNWAY_SITE_URL=https://your-project.vercel.app
RUNWAY_TEST_EMAIL=your-test-email@example.com
RUNWAY_TEST_PASSWORD=your-test-password

# Tidal OAuth client credentials
TIDAL_CLIENT_ID=your_tidal_client_id
TIDAL_CLIENT_SECRET=your_tidal_client_secret

# Spotify MCP
SPOTIFY_MCP_CMD=node
SPOTIFY_MCP_CWD=/absolute/path/to/spotify-mcp-server
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Tidal MCP
TIDAL_MCP_CMD=node
TIDAL_MCP_CWD=/absolute/path/to/tidal-mcp-server

# Feed ingestion shared secret (server-to-server)
FEED_INGEST_SECRET=your_random_secret_here

# LLM integration (server-only, never prefix with NEXT_PUBLIC_)
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL_KIMI=openai/gpt-4o
LLM_MODEL_CLAUDE=anthropic/claude-3.5-sonnet
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=3
